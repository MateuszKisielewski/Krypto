<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.TextFlow?>

<AnchorPane prefHeight="460.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.desx.gui.AppWindow">
    <children>
        <Button fx:id="start" layoutX="280.0" layoutY="267.0" mnemonicParsing="false" onAction="#onStart" text="Start" />
      <TextFlow layoutX="26.0" layoutY="204.0" prefHeight="200.0" prefWidth="200.0">
         <children>
            <TextArea id="tekstJawny" fx:id="tekstJawny" prefHeight="203.0" prefWidth="202.0" promptText="tekst jawny" />
         </children>
      </TextFlow>
      <TextArea id="tekstZaszyfrowany" fx:id="tekstZaszyfrowany" layoutX="379.0" layoutY="205.0" prefHeight="200.0" prefWidth="200.0" promptText="tekst zaszyfrowany" />
      <TextField id="kluczPierwszy" fx:id="kluczPierwszy" layoutX="48.0" layoutY="14.0" promptText="klucz pierwszy" />
      <Button fx:id="generujKlucze" layoutX="148.0" layoutY="47.0" mnemonicParsing="false" onAction="#onGenerujKlucze" text="Generuj klucze" />
      <Button fx:id="wczytajPlik" layoutX="394.0" layoutY="164.0" mnemonicParsing="false" onAction="#onWczytajPlik" text="Wczytaj plik" />
      <RadioButton fx:id="szyfrujButton" layoutX="270.0" layoutY="207.0" mnemonicParsing="false" text="Szyfruj">
         <toggleGroup>
            <ToggleGroup fx:id="choice" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="deszyfrujButton" layoutX="269.0" layoutY="237.0" mnemonicParsing="false" text="Deszyfruj" toggleGroup="$choice" />
      <Button fx:id="zapiszPlik" layoutX="394.0" layoutY="127.0" mnemonicParsing="false" onAction="#onZapiszPlik" text="Zapisz plik" />
      <Button fx:id="zapiszKlucze" layoutX="261.0" layoutY="47.0" mnemonicParsing="false" onAction="#onZapiszKlucze" text="Zapisz klucze" />
      <Button fx:id="wczytajKlucze" layoutX="370.0" layoutY="47.0" mnemonicParsing="false" onAction="#onWczytajKlucze" text="Wczytaj klucze" />
      <TextField id="kluczDrugi" fx:id="kluczDrugi" layoutX="227.0" layoutY="14.0" promptText="klucz drugi" />
      <TextField id="kluczTrzeci" fx:id="kluczTrzeci" layoutX="406.0" layoutY="14.0" promptText="klucz trzeci" />
      <RadioButton layoutX="53.0" layoutY="150.0" mnemonicParsing="false" text="Wprowadzanie ręczne">
         <toggleGroup>
            <ToggleGroup fx:id="wprowadzanie" />
         </toggleGroup>
      </RadioButton>
      <RadioButton layoutX="53.0" layoutY="171.0" mnemonicParsing="false" text="Wprowadzanie z pliku" toggleGroup="$wprowadzanie" />
    </children>
</AnchorPane>
